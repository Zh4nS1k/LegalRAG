# ── [LegalRAG Production Environment Template] ──────────────────────────────────
# Instructions: Copy this file to `.env` in the project root and fill in the values.

# ├── AI Cloud Services ────────────────────────────────────────────────────────
# Groq: Used as the primary LLM engine. Get your key at https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Pinecone: Used for vector storage and similarity search. Get your key at https://app.pinecone.io
PINECONE_API_KEY="pcsk_your_pinecone_api_key_here"
PINECONE_INDEX_NAME="legally-index"
PINECONE_NAMESPACE="default"

# Hugging Face: Used for fetching the embedding model (intfloat/multilingual-e5-large)
# Optional but highly recommended to avoid rate limits and warnings.
HF_TOKEN="hf_your_huggingface_token_here"

# ├── Performance & Optimization ───────────────────────────────────────────────
# Offline Mode: Set to 1 if you have already downloaded the embedding model
# to skip the Hugging Face hub network check and drastically speed up boot time.
HF_HUB_OFFLINE="0"
LEGAL_RAG_HF_LOCAL_ONLY="0"

# ├── LLM Configuration ────────────────────────────────────────────────────────
# LEGAL_RAG_LLM_BACKEND="groq" # Defaults to groq
# LEGAL_RAG_LLM="llama-3.1-70b-versatile"
# LEGAL_RAG_LLM_MAX_TOKENS="2048"

# ├── Database Configuration (For Go Backend, if applicable) ───────────────────
MONGO_URI="mongodb://localhost:27017"
DB_NAME="legally_bot"

# ├── Access Management ────────────────────────────────────────────────────────
JWT_SECRET="your_jwt_secret_here"
ADMIN_IDS="991315506"
